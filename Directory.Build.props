<Project>
  <PropertyGroup>
    <_GridForgeHostPlatform Condition="$([MSBuild]::IsOSPlatform('Windows'))">windows</_GridForgeHostPlatform>
    <_GridForgeHostPlatform Condition="'$(_GridForgeHostPlatform)' == '' And $([MSBuild]::IsOSPlatform('OSX'))">macos</_GridForgeHostPlatform>
    <_GridForgeHostPlatform Condition="'$(_GridForgeHostPlatform)' == ''">unix</_GridForgeHostPlatform>
    <DefaultItemExcludes>$(DefaultItemExcludes);bin/**;obj/**</DefaultItemExcludes>
    <BaseIntermediateOutputPath Condition="'$(BaseIntermediateOutputPath)' == ''">obj/$(_GridForgeHostPlatform)/</BaseIntermediateOutputPath>
    <MSBuildProjectExtensionsPath Condition="'$(MSBuildProjectExtensionsPath)' == '' And '$(MSBuildProjectName)' != 'BenchmarkDotNet.Autogenerated'">$(BaseIntermediateOutputPath)</MSBuildProjectExtensionsPath>
    <IntermediateOutputPath Condition="'$(IntermediateOutputPath)' == '' And '$(TargetFramework)' != '' And '$(MSBuildProjectName)' != 'BenchmarkDotNet.Autogenerated'">$(BaseIntermediateOutputPath)$(Configuration)/$(TargetFramework)/</IntermediateOutputPath>
  </PropertyGroup>
</Project>
